# Monorepo root

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Env secrets (keep examples)
.env
.env.local
.env.*.local
!**/.env.example
!**/.env.example.studio

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/*.tsbuildinfo

# Backend
backend/bin/
backend/*.exe
backend/server
backend/tmp/
backend/vendor/

# Logs
*.log
npm-debug.log*
