SERVER_HOST=0.0.0.0
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-production
DB_HOST=localhost
DB_PORT=5432
DB_USER=masterfabric
DB_PASSWORD=masterfabric
DB_NAME=masterfabric
DB_SSLMODE=disable
KAFKA_ENABLED=false
APP_ENV=development
# Phase 3 LLM (provider-agnostic). Dev default: mock. Live Gemma/MLC: OpenAI-compatible base URL.
# Example Ollama: LLM_PROVIDER=gemma LLM_BASE_URL=http://localhost:11434/v1 LLM_MODEL=gemma2
# Example Hugging Face Inference: LLM_PROVIDER=gemma LLM_BASE_URL=https://router.huggingface.co/v1 LLM_MODEL=google/gemma-2-2b-it:featherless-ai LLM_API_KEY=hf_...
# Example Compose MLC mock: LLM_PROVIDER=gemma LLM_BASE_URL=http://localhost:8081/v1 LLM_MODEL=mock-mlc-model
LLM_ENABLED=true
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_ALLOW_MOCK_IN_PRODUCTION=false
# Sync generate can exceed the default 15s write timeout — keep write timeout > LLM timeout.
SERVER_WRITE_TIMEOUT_SECONDS=90
SERVER_READ_TIMEOUT_SECONDS=15

# Phase 5 Compose stack (when using make compose-up-full)
# API via nginx LB: http://localhost:8080
# MLC mock direct: http://localhost:8081
# Grafana: http://localhost:3001 (admin/admin)
# Prometheus: http://localhost:9090

LOG_LEVEL=info
LOG_FORMAT=json
REDIS_HOST=localhost
REDIS_PORT=6379
